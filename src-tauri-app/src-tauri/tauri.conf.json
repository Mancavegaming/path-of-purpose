{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Path of Purpose",
  "version": "0.1.0",
  "identifier": "com.pathofpurpose.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Path of Purpose",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGOUFCODQyQTcxMkY4OEQKUldTTitCS25RcmlhVHpibFhpQW9aT1hzeTkrdGhiZktUU3VvdFVKTXdKbzNvaUIyY3F2Y3ljVEgK",
      "endpoints": [
        "https://github.com/Mancavegaming/path-of-purpose/releases/latest/download/latest.json"
      ]
    }
  }
}
